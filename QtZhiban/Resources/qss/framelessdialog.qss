QPushButton { padding:0px 10px 0px 10px; border:1px solid #E1E1E1; background-color:#FFFFFF;}
QPushButton:hover { padding:0px 10px 0px 10px; border-top:2px solid #E1E1E1; border-left:2px solid #E1E1E1;}
QPushButton:pressed { padding:0px 10px 0px 10px; border-top:#E1E1E1; border-bottom:none; background-color:#FFC96C;color:#FFFFFF;}

QCheckBox { spacing: 5px; background: transparent; border: none;}
