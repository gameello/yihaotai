QWidget { border: 1px solid #B5B5B5; color:#333333; font-family:"Microsoft YaHei"; font-size:14px;}
/* QWidget { background-color: qlineargradient(spread:pad, x1:0, y1:1, x2:0, y2:0, stop:0 rgba(9, 41, 72, 255), stop:1 rgba(15, 35, 53, 255));} */

QLabel { background: transparent; border: none;}
QLabel:disabled { color: rgb(160,160,164);}
