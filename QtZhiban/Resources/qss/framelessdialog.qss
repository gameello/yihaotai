QGroupBox { background: transparent; border: 1px solid #B5B5B5; color: #F98500; margin-top: 2ex;}
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; left:10px; margin-left:0px; padding:0 1px;}

QTableView{ background-color:#FFFFFF; alternate-background-color:#EAEEF0; selection-background-color:#FFD88B;}
QTableCornerButton::section{border:none; padding: -1px;color:white;background-color:#DDEBFF;}

QHeaderView { border: 1px solid #E1EEFF; padding: -1px; background-color:#DDEBFF;}
QHeaderView::section:horizontal { border: 1px solid #E5E5E5; padding: -2px; min-height: 30px; background-color:#E1EEFF;}
QHeaderView::section:vertical { background: transparent; border:1px solid #E5E5E5; padding:-2px; min-width:30px; width:30px; }
QHeaderView::section:checked{ background-color:#E1EEFF;}
QHeaderView::section:hover{background-color:#FFD88B;}

QListWidget{ text-align: center; border: 1px solid rgb(44,80,114);}
QListWidget::item:hover { border: 1px solid #2D7EDF;}
QListWidget::item:selected { border: 1px solid #2D7EDF; color:rgb(249,133,0);}

QStackedWidget { border: none;}

QScrollBar { background:transparent; border:1px solid #B5B5B5; }
QScrollBar::add-page, QScrollBar::sub-page { background:#F9F9F9;}
QScrollBar::add-line, QScrollBar::sub-line { border: 1px solid #B5B5B5; background:#F9F9F9; width: 10px; height: 10px; subcontrol-origin: margin; }

QScrollBar:horizontal { height: 12px; margin: 0px 11px;}
QScrollBar::handle:horizontal { height:10px; border:#E5E5E5;background-color:#90C5FF;}
QScrollBar::handle:horizontal:hover { background-color:#1F76D8;}
QScrollBar::handle:horizontal:pressed { background-color:#1F76D8;}
QScrollBar::add-line:horizontal { subcontrol-position: right;}
QScrollBar::sub-line:horizontal { subcontrol-position: left;}
QScrollBar::left-arrow:horizontal, QScrollBar::right-arrow:horizontal { width: 6px; height: 8px;}
QScrollBar::left-arrow:horizontal { image: url(:/images/dialog/left.png);}
QScrollBar::left-arrow:horizontal:hover { image: url(:/images/dialog/left_hover.png);}
QScrollBar::left-arrow:horizontal:pressed { image: url(:/images/dialog/left_pressed.png);}
QScrollBar::right-arrow:horizontal { image: url(:/images/dialog/right.png);}
QScrollBar::right-arrow:horizontal:hover { image: url(:/images/dialog/right_hover.png);}
QScrollBar::right-arrow:horizontal:pressed { image: url(:/images/dialog/right_pressed.png);}

QScrollBar:vertical { width: 12px; margin: 11px 0px; }
QScrollBar::handle:vertical { height:10px; border:#E5E5E5;background-color:#90C5FF;}
QScrollBar::handle:vertical:hover { background-color:#1F76D8;}
QScrollBar::handle:vertical:pressed { background-color:#1F76D8;}
QScrollBar::add-line:vertical { subcontrol-position: bottom;}
QScrollBar::sub-line:vertical { subcontrol-position: top;}
QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical { width: 8px; height: 6px;}
QScrollBar::up-arrow:vertical { image: url(:/images/dialog/up.png);}
QScrollBar::up-arrow:vertical:hover { image: url(:/images/dialog/up_hover.png);}
QScrollBar::up-arrow:vertical:pressed { image: url(:/images/dialog/up_pressed.png);}
QScrollBar::down-arrow:vertical { image: url(:/images/dialog/down.png);}
QScrollBar::down-arrow:vertical:hover { image: url(:/images/dialog/down_hover.png);}
QScrollBar::down-arrow:vertical:pressed { image: url(:/images/dialog/down_pressed.png);}

QSplitter::handle{background:transparent;}

