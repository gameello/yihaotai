QTableView{
	outline:none;
	gridline:1px solid #19000000;;
	color:#FFFFFF;
	font-family:"Microsoft YaHei"; 
	font-size:14px;
	border:1px solid #0175ae;
	background:#024c87;
	alternate-background-color:#015293;
	selection-color:#FFFFFF;
	selection-background-color:#0097df;
}
QScrollBar { background:transparent; border:none;}
QScrollBar::add-page, QScrollBar::sub-page { background:transparent;border:none;}
QScrollBar::add-line, QScrollBar::sub-line { border: none; background:transparent; width: 10px; height: 10px; subcontrol-origin: margin; }
/*水平滑块样式*/
QScrollBar:horizontal { height: 8px; margin: 0px 11px;}
QScrollBar::handle:horizontal { height:6px; border-radius:2px; border:1px solid #007ac0;background-color:#007ac0;margin-left:1px;margin-right:1px;}
QScrollBar::handle:horizontal:hover { background-color:#0097df;}
QScrollBar::handle:horizontal:pressed { background-color:#0097df;}
QScrollBar::add-line:horizontal { subcontrol-position: right;}
QScrollBar::sub-line:horizontal { subcontrol-position: left;}
/*
QScrollBar::left-arrow:horizontal, QScrollBar::right-arrow:horizontal { width: 6px; height: 8px;}
QScrollBar::left-arrow:horizontal { image: url(:/images/dialog/left.png);}
QScrollBar::left-arrow:horizontal:hover { image: url(:/images/dialog/left_hover.png);}
QScrollBar::left-arrow:horizontal:pressed { image: url(:/images/dialog/left_pressed.png);}
QScrollBar::right-arrow:horizontal { image: url(:/images/dialog/right.png);}
QScrollBar::right-arrow:horizontal:hover { image: url(:/images/dialog/right_hover.png);}
QScrollBar::right-arrow:horizontal:pressed { image: url(:/images/dialog/right_pressed.png);}
*/
QScrollBar:vertical { width: 8px; border:none;}
QScrollBar::handle:vertical { width:6px; border-radius:2px; border:1px solid #007ac0;background-color:#007ac0;margin-left:1px;margin-right:1px;}/*垂直滑块样式*/
QScrollBar::handle:vertical:hover { background-color:#0097df;}
QScrollBar::handle:vertical:pressed { background-color:#0097df;}
QScrollBar::add-line:vertical { subcontrol-position: bottom;}/*向下箭头样式*/
QScrollBar::sub-line:vertical { subcontrol-position: top;}/*向上箭头样式*/
/*
QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical { width: 8px; height: 12px;}
QScrollBar::up-arrow:vertical { image: url(:/images/dialog/up.png);}
QScrollBar::up-arrow:vertical:hover { image: url(:/images/dialog/up_hover.png);}
QScrollBar::up-arrow:vertical:pressed { image: url(:/images/dialog/up_pressed.png);}
QScrollBar::down-arrow:vertical { image: url(:/images/dialog/down.png);}
QScrollBar::down-arrow:vertical:hover { image: url(:/images/dialog/down_hover.png);}
QScrollBar::down-arrow:vertical:pressed { image: url(:/images/dialog/down_pressed.png);}
*/

QDateEdit{height:32px;color:#FFFFFF;border: 1px solid #0175ae;background:transparent;selection-color:#ffae3b;}
QDateEdit::drop-down{width:20px;border:none;background:transparent;padding:0px 2px 0px 2px;}
QDateEdit::down-arrow{image:url(:/images/right/popup_btn_forward_back.png);}
QDateEdit::down-arrow:hover{image:url(:/images/right/popup_btn_hover_back.png);}
QDateEdit::up-arrow{image:url(:/images/right/popup_btn_forward_normal.png);}
QDateEdit::up-arrow:hover{image:url(:/images/right/popup_btn_hover_normal.png);}

QTimeEdit{height:32px;color:#FFFFFF;border: 1px solid #0175ae;}
QTimeEdit::drop-down{width:20px;border:none;background:transparent;}
QTimeEdit::down-arrow{image:url(:/images/right/popup_btn_forward_back.png);}
QTimeEdit::down-arrow:hover{image:url(:/images/right/popup_btn_hover_back.png);}
QTimeEdit::up-arrow{image:url(:/images/right/popup_btn_forward_normal.png);}
QTimeEdit::up-arrow:hover{image:url(:/images/right/popup_btn_hover_normal.png);}

QDateTimeEdit{height:32px;color:#FFFFFF;border: 1px solid #0175ae;background:transparent;selection-color:#ffae3b;}
QDateTimeEdit::drop-down{width:20px;border:none;background:transparent;padding:0px 2px 0px 2px;}
QDateTimeEdit::down-arrow{image:url(:/images/right/popup_btn_forward_back.png);}
QDateTimeEdit::down-arrow:hover{image:url(:/images/right/popup_btn_hover_back.png);}
QDateTimeEdit::up-arrow{image:url(:/images/right/popup_btn_forward_normal.png);}
QDateTimeEdit::up-arrow:hover{image:url(:/images/right/popup_btn_hover_normal.png);}

QDoubleSpinBox{height:32px;color:#FFFFFF;border: 1px solid #0175ae;background:transparent;selection-color:#ffae3b;}
QDoubleSpinBox::drop-down{width:20px;border:none;background:transparent;padding:0px 2px 0px 2px;}
QDoubleSpinBox::down-arrow{image:url(:/images/right/popup_btn_forward_back.png);}
QDoubleSpinBox::down-arrow:hover{image:url(:/images/right/popup_btn_hover_back.png);}
QDoubleSpinBox::up-arrow{image:url(:/images/right/popup_btn_forward_normal.png);}
QDoubleSpinBox::up-arrow:hover{image:url(:/images/right/popup_btn_hover_normal.png);}

QGroupBox { background: #024c87; border: 1px solid #0175ae; color: rgb(0,216,255); margin-top: 2.5ex;}
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; left:6px; margin-left:0px; padding:0 1px;}
QGroupBox::indicator{width:20px;height:20px;margin-top: 2ex; }
QGroupBox::indicator:unchecked{image:url(:/images/right/popup_btn_checkbox_normal.png);}
QGroupBox::indicator:checked{image:url(:/images/right/popup_btn_checkbox_selected.png);}

QScrollArea{
	border:none;
	background:transparent;
}
QTreeWidget{
	outline:none;
	border:none;
}

QTreeWidget::item{
	color: #FFFFFF;
    border:none;
	border-top-right-radius:2px;
	border-bottom-right-radius:2px;
}
QTreeWidget::item:hover{
	color: #ffae3b;
    border:none;
	border-top-right-radius:2px;
	border-bottom-right-radius:2px;
}

QTreeWidget::item:selected:active{
	color: #ffae3b;
    border:none;
	border-top-right-radius:2px;
	border-bottom-right-radius:2px;
}

QTreeWidget::item:selected:!active{
	color: #FFFFFF;
    border:none;
	border-top-right-radius:2px;
	border-bottom-right-radius:2px;
}

QTreeWidget::branch{
	border:none;
	border-top-left-radius:2px;
	border-bottom-left-radius:2px; 
}

QTreeWidget::branch:closed:has-children{
	border-image:none;
	image:url(:/images/tree/tree_close.png);
}
QTreeWidget::branch:closed:has-children:hover{
	border-image:none;
	image:url(:/images/tree/tree_close_hover.png);
}

QTreeWidget::branch:open:has-children{
	border-image:none;
	image:url(:/images/tree/tree_open.png);
}
QTreeWidget::branch:open:has-children:hover{
	border-image:none;
	image:url(:/images/tree/tree_open_hover.png);
}

QTreeWidget::indicator{
	height:22px;
	width:22px;
}

QTreeWidget::indicator:unchecked{
	border-image:none;
    image:url(:/images/tree/checkBox_unchecked.png);
}
QTreeWidget::indicator:unchecked:hover{
	border-image:none;
    image:url(:/images/tree/checkBox_unchecked_hover.png);
}
QTreeWidget::indicator:unchecked:pressed{
    image:url(:/images/tree/checkBox_unchecked_pressed.png);
}
QTreeWidget::indicator:checked{
	image:url(:/images/tree/checkBox_checked.png);
}
QTreeWidget::indicator:checked:hover{
	image:url(:/images/tree/checkBox_checked_hover.png);
}
QTreeWidget::indicator:checked:pressed{
	image:url(:/images/tree/checkBox_checked_pressed.png);
}
QTreeWidget::indicator:indeterminate {
   image: url(:/images/tree/part_checked.png);
}
QTreeWidget::indicator:indeterminate:hover {
   image: url(:/images/tree/part_checked_hover.png);
}
QTreeWidget::indicator:indeterminate:pressed {
   image: url(:/images/tree/part_checked_hover.png);
}

QSpinBox{
    border:1px solid gray;
    border-radius:3px;
    border-color:#31B7D7;
    color:#FFFFFF;
    margin:0px 0px 0px 0px;
    /*padding-top:4px;
    padding-bottom:4px;*/
    padding-left:8px;
    height:30;
}

QSpinBox::up-button{
    subcontrol-position:top right;
    image:url(:/images/right/popup_btn_forward_normal.png);
    padding-right:4px;
}

QSpinBox::down-button{
    subcontrol-position:bottom right;
    image:url(:/images/right/popup_btn_forward_back.png);
    padding-right:4px;
}

QTabWidget::pane{
	border:none;
}

QTabBar{
	background: #0175ae;
	border:none;
}

QTabBar::tab{
	font-family: "Microsoft Yahei";
	height: 24px;
	padding-left: 7px;
	padding-right: 7px;
	margin: 3px;
	color: #FFFFFF;
	border-radius:2px;
}
QTabBar::tab:hover{
	background: #0097df;
	border-bottom:2px solid #0097df;
}

QTabBar::tab:selected{
	background: #0097df;
	border-bottom:2px solid #0097df;
}

QTreeView{
	color: #FFFFFF;
	border: none;
	outline:0px;
	show-decoration-selected:1;
	background:#024c87;
}

QTreeView::item{
	color: #FFFFFF;
	border:none;
	border-top-right-radius:2px;
	border-bottom-right-radius:2px;
}

QTreeView::item:selected{
	background-color:#31BDDD;
}

QWebEngineView{
	background:#024c87;
	color:white;
}
