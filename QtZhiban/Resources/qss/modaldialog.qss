QCheckBox{
    background:transparent;
	border:none;
    color:#FFFFFF;
    font-family:"Microsoft YaHei"; 
    font-size:14px;
}
QCheckBox::indicator:unchecked{	
	image: url(:/images/right/popup_btn_checkbox_normal.png);
}
QCheckBox::indicator:checked{	
	image: url(:/images/right/popup_btn_checkbox_selected.png);
}
QCheckBox::indicator:unchecked:disabled{
	image: url(:/images/right/popup_btn_checkbox_hover_dis.png);
}
QCheckBox::indicator:checked:disabled{
	image: url(:/images/right/popup_btn_checkbox_selected_dis.png);
}
QCheckBox:disabled{
	color:rgb(69,147,208);
}

QRadioButton{
	background:transparent;
}

QRadioButton::indicator:unchecked{		
	image: url(:/images/right/right_radio.png);
	height:32px;	
}
QRadioButton::indicator:checked,QRadioButton::indicator:hover{		
	image: url(:/images/right/right_radio_selected.png);
}
QListWidget{
	background:transparent;
    border-radius:0px;
    border:1px solid #0175ae;
	outline:none;
    color:#FFFFFF; 
}

QListWidget::item:hover{
    background-color:#0d69b2;  
    color:#ffae3b;
}

QListWidget::item{
	height:30px;
	border:none; 
}
QListWidget::item:selected { background:#0d69b2;color:#ffae3b;}
QHeaderView{
	background:#0175ae;
	height:28px;
	border:none;
}
QHeaderView::section{
	outline:0px;
	background-color:#0175ae;
	color:#FFFFFF;
	font-family:"Microsoft YaHei"; 
	font-size:14px;
	height:28px;
	border:1px solid #19000000;
	border-left-width:0px;
	border-right-width:1px;
	border-top-width:0px;
	border-bottom-width:0px;
}
QTableWidget{
	outline:none;
	gridline:1px solid #19000000;;
	color:#FFFFFF;
	font-family:"Microsoft YaHei"; 
	font-size:14px;
	border:1px solid #0175ae;
	background:#024c87;
	alternate-background-color:#015293;
	selection-color:#FFFFFF;
	selection-background-color:#0097df;
}
QTableWidget QLineEdit{
	border:none; 
	background: transparent;
}
