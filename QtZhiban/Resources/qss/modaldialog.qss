QWidget{
	background:#015293;color:#FFFFFF;font-family:"Microsoft YaHei"; font-size:14px;
}

/*QToolTip的样式 */
QToolTip {
    color: rgb(69,147,208); /* 设置tooltip文字颜色 */
    background-color: lightgray; /* 设置tooltip背景颜色 */
}

QPushButton{   
	background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #00a9ed, stop:1 #1f82da);	
    color:#FFFFFF;
    font-family:"Microsoft YaHei"; 
    font-size:14px;
    border-radius:2px;
	width:64px;
	height:28px;
}
QPushButton:pressed,QPushButton:hover,QPushButton:checked{
	background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #ffb33b, stop:1 #ff903b);
	border:none;
}
QPushButton:disabled{
	background-color:#0d69b2;
	color:rgb(69,147,208);
}
/*QLabel的样式 */
QLabel{ 
	background:transparent;
	color:#FFFFFF;font-family:"Microsoft YaHei";
	font-size:14px;border:none;
	height:28px;
}
QLabel:disabled{ color:rgb(69,147,208);}

/*QLineEdit的样式 */
QLineEdit{
	border:1px solid #0175ae;background:#024c87;
	border-radius:2px;padding:0px 0px 0px 12px;
	height:28px;
	color:#FFFFFF;
	font-family:"Microsoft YaHei"; 
	font-size:14px;
}
QLineEdit:hover,QLineEdit:focus{
	border:1px solid #ffae3b;
}
QLineEdit:disabled { 
	color: #0175ae; 
	border: 1px solid #0175ae; 
}
QTextEdit { background:#024c87; border: 1px solid #0175ae;}
/*QScrollBar{border:none;}*/
/*未下拉时，QComboBox的样式*/
QComboBox{
	border:1px solid #0175ae;
	background:#024c87;
	border-radius:2px;
	padding-left:12px;
	color:#FFFFFF;
    font-family:"Microsoft YaHei"; 
    font-size:14px;
	height:28px;
}
QComboBox:on,QComboBox:hover{
	border:1px solid #ffae3b;
}
QComboBox:disabled { 
	color: #FFFC00; 
	border: 1px solid #0175ae; 
}
/*下拉时，QComboBox的样式*/
QComboBox::drop-down{
	width:30px;
	border:none;
	padding:0px 0px 0px 0px;
}

QComboBox::down-arrow{	
	image: url(:/images/right/right_btn_combo.png);	
}
QComboBox::down-arrow:on{	
	image: url(:/images/right/right_btn_combo_pre.png);
}
/*下拉后，整个下拉窗体的样式*/
QComboBox QAbstractItemView{
	outline:none;
	border-top-width:1px;
	border-top-color:#ffae3b;
	border-top-style:solid;
	border-radius:2px;
	color:#FFFFFF;
	selection-background-color:#024479;
	background:#024c87;
	margin:0px 0px 0px 0px;	
}

/*下拉后，整个下拉窗体每项的样式*/
QComboBox QAbstractItemView::item{
	height:32px;
	border-radius:2px;
	padding-left:12px;
	font-family:"Microsoft YaHei"; 
    font-size:14px;
}

/*下拉后，整个下拉窗体越过每一项的样式*/
QComboBox QAbstractItemView::item:hover:selected{
	background-color:#024479;
}

/*下拉后，QComboxBox垂直滚动条的样式*/
